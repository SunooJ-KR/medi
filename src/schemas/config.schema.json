{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["company", "markets", "default_market", "channels", "default_channels", "competitors", "scan"],
  "properties": {
    "company": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "official_urls"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "official_urls": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "markets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["KR", "US", "JP", "SEA"] }
    },
    "default_market": { "type": "string", "enum": ["KR", "US", "JP", "SEA"] },
    "channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "default_channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "competitors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "keywords"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "keywords": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lookback_weeks", "extra_keywords", "source_whitelist"],
      "properties": {
        "lookback_weeks": { "type": "integer", "minimum": 1, "maximum": 52 },
        "extra_keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_whitelist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
