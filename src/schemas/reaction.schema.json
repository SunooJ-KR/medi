{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reaction.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "persona_id",
    "event_id",
    "deltas",
    "direction",
    "predicted_behaviors",
    "suggested_actions",
    "confidence",
    "rationale",
    "evidence_refs"
  ],
  "properties": {
    "persona_id": { "type": "string", "pattern": "^p[0-9]{2}_[a-z0-9_]+$" },
    "event_id": { "type": "string", "pattern": "^evt_[0-9]{4}_[a-z0-9_]+$" },
    "deltas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["motivation", "ability", "prompt"],
      "properties": {
        "motivation": { "type": "integer", "minimum": -2, "maximum": 2 },
        "ability": { "type": "integer", "minimum": -2, "maximum": 2 },
        "prompt": { "type": "integer", "minimum": -2, "maximum": 2 }
      }
    },
    "direction": { "type": "string", "enum": ["opportunity", "risk", "neutral"] },
    "predicted_behaviors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "suggested_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "rationale": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
